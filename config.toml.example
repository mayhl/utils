# mayhl_utils configuration (TOML).
#
# The real file — config.toml — is gitignored (it carries your HPC username and
# HPC cluster hostnames). Copy this to config.toml and fill it in:
#
#     cp config.toml.example config.toml
#
# The mu engine reads config.toml directly (any omitted value falls back to a
# built-in default). Platform seams (MU_SSH — ossh vs ssh by mode) and terminal
# state (NO_COLOR, COLUMNS, …) are NOT set here; they stay environment-sourced.

hpc_user = "your_hpc_username"

# fleet — explicit node list that `--fleet` (and bare mstat off HPC) queries, one queue
# fetch per node. Use when a DSRC's nodes are SEPARATE schedulers (each its own queue):
# list every system so the collate doesn't collapse them to one representative node. Omit
# to fall back to one node per active cluster. Each name must be a node defined below.
# fleet = ["node-a", "node-d"]

[transfer]
rsync_opts        = "-au --partial"   # base rsync opts (NO -v/-P/--progress — the tool owns progress)
ssh_transfer_opts = "-q"              # quiet ssh for transfers (suppress the login banner)

[sshfs]
root = "~/hpc_sshfs"                  # local parent dir for `mu sshfs` mounts

[ssh]
# ossh = "/path/to/ossh/bin/ssh"     # Kerberos ssh build if it's a shell alias (give the
                                     # binary path); omit to use the system ssh on PATH

[shell]
# queue_aliases — which word the queue view/cancel front-doors use (pure ergonomics;
# the engine auto-detects each cluster's real scheduler regardless):
#   "pbs"   (default) → mstat / mdel      (qstat/qdel idiom)
#   "slurm"           → mqueue / mcancel  (squeue/scancel idiom; REPLACES mstat/mdel)
#   "both"            → all four
# The process front-doors (mps/mkill) and the scheduler-neutral queue verbs
# (minfo/mpeek/mhold/mrls/mhist) are always defined, whatever this is set to.
# queue_aliases = "pbs"

# One [[cluster]] block per HPC cluster. Order is preserved (array of tables) and drives
# node resolution, the per-node shell dispatchers, and the queue plane.
#   scheduler = "pbs" | "slurm"  — which command the live `mu hpc queue` fetch runs.
#   active    = true | false     — in the --fleet set (omit → true); set false for a
#                                  configured-but-unused cluster so --fleet (and bare
#                                  mstat off HPC) skip it. --all includes it regardless.
#   account   = "ALLOC-ID"       — optional default allocation `mu job sub` charges
#                                  (-A overrides); omit to use the script's own directive.
#   interactive_walltime = "1h"  — how long a HELD session (`mu job shell`, `mu job tunnel`)
#                                  asks for; HH:MM:SS or a duration (10m, 1h, 1.5h, 1h30m).
#                                  Clamped down to the queue's own maximum, so one value works
#                                  across machines whose debug queue caps at 30m or at 1h.
#                                  NOT used by `mu job sub`: a batch script declares its own
#                                  walltime, and a qsub -l would silently override it.
#   cores_per_node = 128         — cores per compute node; enables the `mu hpc queues`
#                                  MaxNodes column (ceil(MaxCores / cores_per_node)). Omit
#                                  → MaxNodes shows "--".
#   queue_class = { q = "GPU" }  — force a queue's node class when the name heuristic is
#                                  wrong (CPU/GPU/VIS/BigMem/Transfer/Archive).
#   queue_cores = { q = 64 }     — per-queue cores/node override (GPU/specialty nodes whose
#                                  core count differs from cores_per_node; feeds MaxNodes).
#   submit_queue = { default = "standard", gpu = "gpu_short" }
#                                — queues `mu job sub` targets: `default` applies when no
#                                  -q / selector flag is given; gpu/vis/bigmem/xfer/debug/
#                                  background back the selector flags (--gpu, --vis, …). A
#                                  missing class entry is resolved from the live queue list;
#                                  --debug/--background fall back to those standard names.
#
# A cluster groups the machines behind one DSRC domain — it is NOT one queue plane. Machines
# under it differ in cores/node, queue names, allocation, sometimes the scheduler itself, so
# every field above is a DEFAULT that a [[cluster.node]] block overrides for one machine:
#
#   [[cluster.node]]
#   name           = "node-b"
#   cores_per_node = 192
#   submit_queue   = { debug = "debug-b" }
#
# Lookups read node-first, cluster-second, and the maps merge PER KEY — node-b above still
# submits to the cluster's `default` queue. A node named only in a node block joins the
# cluster (no need to list it in `nodes` as well).
[[cluster]]
name      = "dsrc1"
domain    = "dsrc1.example.hpc.mil"
nodes     = ["node-a", "node-b", "node-c"]
scheduler = "slurm"
account   = "ALLOC-1234"
interactive_walltime = "1h"
cores_per_node = 128
# queue_class = { "gpu-debug" = "GPU" }
# queue_cores = { "gpu-debug" = 64 }
# submit_queue = { default = "standard", gpu = "gpu-debug" }

  # node-b is the odd machine out: fatter nodes, its own debug queue and allocation.
  [[cluster.node]]
  name           = "node-b"
  account        = "ALLOC-5678"
  cores_per_node = 192
  submit_queue   = { debug = "debug-b" }

[[cluster]]
name      = "dsrc2"
domain    = "dsrc2.example.hpc.mil"
nodes     = ["node-d", "node-e"]
scheduler = "pbs"
active    = false   # configured but not in daily use → skipped by --fleet
