# defaults.env — tracked behavior knobs, shared across macOS + HPC.
#
# Machine identity and cluster inventory live in config.env (gitignored), which
# is sourced AFTER this file and therefore overrides anything set here.
# `:=` means "only set if the caller/config has not already set it".

: "${MU_HPC_RSYNC_OPTS:=-avuP}"; export MU_HPC_RSYNC_OPTS
: "${MU_HPC_SSH_OPTS:=-Y}";      export MU_HPC_SSH_OPTS
: "${MU_HPC_PYTHON:=python}";    export MU_HPC_PYTHON
