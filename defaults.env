# defaults.env — tracked behavior knobs, shared across macOS + HPC.
#
# Machine identity and cluster inventory live in config.env (gitignored), which
# is sourced AFTER this file and therefore overrides anything set here.
# `:=` means "only set if the caller/config has not already set it".

: "${MU_HPC_RSYNC_OPTS:=-au --partial}"; export MU_HPC_RSYNC_OPTS   # base TRANSFER opts only (no -v/-P/--progress/--info); the tool owns progress
: "${MU_SSH_TRANSFER_OPTS:=-q}"; export MU_SSH_TRANSFER_OPTS        # quiet ssh for transfers only (suppress login banner)
: "${MU_HPC_SSH_OPTS:=-Y}";      export MU_HPC_SSH_OPTS
: "${MU_PYTHON:=python3}";       export MU_PYTHON
: "${MU_PY_VENV:=${HOME}/.cache/mayhl_utils/venv}"; export MU_PY_VENV
: "${MU_SSHFS_ROOT:=${HOME}/hpc_sshfs}"; export MU_SSHFS_ROOT   # local sshfs mount parent (mu sshfs)
