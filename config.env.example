# HPC Configuration Template
# Copy this file to 'config.env' and fill in your details.

# The variable names here MUST match the cluster names defined in HPC_HOSTS (in uppercase)
# For example, if HPC_HOSTS="cluster1 cluster2", you must define:
#   export MU_CLUSTER1_HOST='...'
#   export MU_CLUSTER1_HPCS='...'
#   export MU_CLUSTER2_HOST='...'
#   export MU_CLUSTER2_HPCS='...'

# HPC Username
export MU_HPC_UNAME=your_username

# List of clusters (space-separated)
export HPC_HOSTS="cluster1 cluster2"

# Cluster host addresses (Suffix _HOST)
export MU_CLUSTER1_HOST='cluster1.domain.com'
export MU_CLUSTER2_HOST='cluster2.domain.com'

# Cluster members (Suffix _HPCS, space-separated)
export MU_CLUSTER1_HPCS='node1 node2'
export MU_CLUSTER2_HPCS='node3 node4'

# RSync/SSH options
export MU_HPC_RSYNC_OPTS='-avuP'
export MU_HPC_SSH_OPTS='-Y'
export MU_HPC_PYTHON=python
