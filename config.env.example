# config.env — machine identity & cluster inventory.
# Copy to config.env (gitignored) and fill in. Behavior knobs (rsync/ssh
# options, python) live in defaults.env, not here.

# Login name on the HPCs.
export MU_HPC_UNAME=your_username

# Clusters (HPC cluster groups) to generate ssh/copy aliases for. List them lowercase;
# each needs matching _DOMAIN and _NODES vars keyed by the ALL-CAPS name. Names
# must be valid shell identifiers (letters/digits/underscore).
export MU_CLUSTERS="alpha bravo"

# alpha
export MU_CLUSTER_ALPHA_DOMAIN='alpha.example.mil'
export MU_CLUSTER_ALPHA_NODES='node1 node2'

# bravo
export MU_CLUSTER_BRAVO_DOMAIN='bravo.example.mil'
export MU_CLUSTER_BRAVO_NODES='node3 node4'
