#!/usr/bin/env bash
# Safety stub: reports a live ticket for the sandbox user so EnsureTicket is satisfied
# and never reaches pkinit. Needed by tests that must run WITHOUT MU_SYSTEM=hpc (the
# sshfs verbs are registered local-only), where the env guard can't short-circuit it.
cat <<'EOF'
Credentials cache: sandbox
Default principal: tester@SANDBOX.LOCAL

Valid Starting       Expires              Service Principal
01/01/2099 00:00:00  12/31/2099 00:00:00  krbtgt/SANDBOX.LOCAL@SANDBOX.LOCAL
EOF
